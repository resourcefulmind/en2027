# Copy to .env.local and fill with real values (see docs/DATA_SETUP.md).
# .env.local is gitignored — NEVER commit real credentials.

# --- RSVP → Google Sheet (server-only) ---
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the JSON key's private_key value, keeping the \n escapes, wrapped in quotes:
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY=
# The id from the Sheet URL: docs.google.com/spreadsheets/d/<THIS>/edit
RSVP_SHEET_ID=

# --- Well-Wishes → Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
# Service-role key (server-only — never the anon key here, never shipped to the browser)
SUPABASE_SERVICE_ROLE_KEY=
